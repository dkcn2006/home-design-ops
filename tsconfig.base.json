{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@home-design-ops/shared": [
        "packages/shared/src"
      ],
      "@home-design-ops/shared/*": [
        "packages/shared/src/*"
      ]
    }
  }
}

